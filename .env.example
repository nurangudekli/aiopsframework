# =============================================================================
# GenAI Ops Framework - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values.
#
# Most developers/testers only need the "Default Model Endpoint" section below.
# Register additional model endpoints via the Model Endpoints page in the UI.

# --- Application ---
APP_NAME=GenAI Ops Framework
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./genaiops.db
# For production: DATABASE_URL=postgresql://user:password@host:5432/genaiops

# =============================================================================
# DEFAULT MODEL ENDPOINT (used as fallback when no registered model endpoint is selected)
# =============================================================================
# You can also register model endpoints via the UI at /model-endpoints instead
# of setting these variables. The UI approach is recommended for most users.

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-06
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# --- OpenAI (direct) ---
OPENAI_API_KEY=
OPENAI_ORG_ID=

# --- Model Provider B (for A/B testing) ---
MODEL_B_PROVIDER=azure_openai
MODEL_B_API_KEY=
MODEL_B_ENDPOINT=
MODEL_B_DEPLOYMENT_NAME=

# =============================================================================
# OPTIONAL — only needed for Azure Monitor subscription scanning
# =============================================================================
# If you don't have Azure subscription access, skip these. The framework works
# fully with just a model endpoint URL + API key registered via the Model Endpoints page.
#
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=

# --- Redis (for caching & job queues) ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=change-me-to-a-random-secret-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Cost Tracking ---
COST_ALERT_THRESHOLD_USD=100.0
